# =============================================================================
# FIRE STATION SIMULATION - ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains environment variables for the Fire Station Performance
# Analysis and Simulation Dashboard. Copy this file to .env.local for 
# local development or modify values as needed for your environment.
#
# IMPORTANT: Never commit sensitive credentials to version control!
#
# USAGE: To load these variables in Python, use:
#   import os
#   from dotenv import load_dotenv
#   load_dotenv()
#   osrm_url = os.getenv('OSRM_URL', 'http://localhost:8080/table/v1/driving/')
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
# Core application configuration settings

# OSRM (Open Source Routing Machine) Configuration
# Make sure you have an OSRM instance running at localhost:8080
# OSRM provides routing and travel time calculations for emergency response
# =============================================================================
OSRM_URL=http://localhost:8080/table/v1/driving/
BASE_OSRM_URL=http://localhost:8080
RANDOM_SEED=42
PYTHON_PATH=./.venv/bin/python

# -----------------------------------------------------------------------------
# INPUT DATA CONFIGURATION
# -----------------------------------------------------------------------------
# Paths to input datasets required for fire station analysis and simulation
# These files contain geographic and operational data for the fire department
# =============================================================================
INCIDENTS_CSV_PATH=./data/incidents.csv
STATIONS_CSV_PATH=./data/stations.csv
APPARATUS_CSV_PATH=./data/stations_with_apparatus.csv
BOUNDS_GEOJSON_PATH=./data/bounds.geojson
BEATS_SHAPEFILE_PATH=./data/beats_shpfile.geojson
FIREBEATS_MATRIX_PATH=./data/beats.bin
ZONE_MAP_PATH=./data/zones.csv

# -----------------------------------------------------------------------------
# OUTPUT DATA CONFIGURATION
# -----------------------------------------------------------------------------
# Paths where the fire_simulator C++ program will generate analysis results
# These files are created during simulation runs and contain computed metrics
# =============================================================================
REPORT_CSV_PATH=./logs/incident_report.csv
STATION_REPORT_CSV_PATH=./logs/station_report.csv
DURATION_MATRIX_PATH=./logs/duration_matrix.bin
DISTANCE_MATRIX_PATH=./logs/distance_matrix.bin
MATRIX_CSV_PATH=./logs/matrix.csv