# Backend HTTP port (used by uvicorn and docker-compose)
BACKEND_PORT=8000

# Frontend dev-server port + the URL it proxies API calls to in dev
VITE_PORT=5173
VITE_API_TARGET=http://localhost:8000

# SQLite DB file (relative or absolute)
DATABASE_URL=sqlite:///./storage/app.db

# JWT signing key (override in prod)
SECRET_KEY=dev-secret-change-me

# Login throttling
MAX_ATTEMPTS=5

# Filesystem root for job artifacts
STORAGE_ROOT=./storage

# OSRM service used by the C++ simulator. The port must match whichever your
# osrm-routed container is bound to. Defaults:
#   - native dev / bundled docker-compose: host port 8080 -> OSRM container 5000
#   - inside the compose network the backend reaches OSRM at osrm:5000 (set in compose env)
OSRM_HOST=localhost
OSRM_PORT=8080

# Host port for OSRM when running via docker-compose (maps to OSRM's internal 5000)
OSRM_HOST_PORT=8080

# Path to compiled C++ simulator binary
SIMULATOR_BINARY=./data/fire_simulator
